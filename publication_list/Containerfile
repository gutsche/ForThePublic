# Base image
FROM docker.io/library/ubuntu:24.04

# System packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    # publication_list: Python + networking
    python3=3.12.3-0ubuntu2.1 \
    python3-pip=24.0+dfsg-1ubuntu1.3 \
    python3-requests=2.31.0+dfsg-1ubuntu1.1 \
    curl=8.5.0-2ubuntu10.8 \
    ca-certificates \
    # publication_list: fonts for PDF generation
    fonts-dejavu=2.37-8 \
    fonts-stix=1.1.1-5 \
    fonts-noto-extra=20201225-2 \
    # cv, talk_list, media_list, profile, academic-webpage: document processing
    make \
    pandoc \
    m4 \
    # cv, talk_list, media_list: XeLaTeX typesetting
    texlive-xetex \
    texlive-latex-recommended \
    texlive-latex-extra \
    texlive-fonts-recommended \
    lmodern \
 && rm -rf /var/lib/apt/lists/*

# Python packages (pip) — publication_list
RUN pip install --no-cache-dir --break-system-packages \
    reportlab==4.4.10 \
    pylatexenc==2.10 \
    bibtexparser==1.4.4

# pandoc-citeproc wrapper: Ubuntu 24.04's pandoc 3.x bundles citeproc
# internally; the old standalone binary is gone. This wrapper lets the
# existing --filter=pandoc-citeproc calls in talk_list and media_list
# keep working by mapping to pandoc's built-in --citeproc.
RUN printf '#!/bin/sh\nexec pandoc --from=json --to=json --citeproc\n' \
    > /usr/local/bin/pandoc-citeproc \
 && chmod +x /usr/local/bin/pandoc-citeproc

# Go + git — required by Hugo 0.75.1 module system (academic-webpage uses go.mod)
RUN apt-get update && apt-get install -y --no-install-recommends golang-go git \
 && rm -rf /var/lib/apt/lists/*

ENV GOPATH=/root/go
ENV PATH=$PATH:/root/go/bin

# Hugo Extended — academic-webpage (Wowchemy theme requires Extended for SCSS).
# 0.105.0 is the first release that ships hugo_extended for Linux ARM64.
# Asset naming differs by arch: Linux-64bit (x86_64) vs linux-arm64 (ARM64).
RUN ARCH=$(uname -m) \
 && if [ "$ARCH" = "aarch64" ]; then \
      HUGO_ASSET="hugo_extended_0.105.0_linux-arm64.tar.gz"; \
    else \
      HUGO_ASSET="hugo_extended_0.105.0_Linux-64bit.tar.gz"; \
    fi \
 && curl -fsSL "https://github.com/gohugoio/hugo/releases/download/v0.105.0/${HUGO_ASSET}" \
    | tar xz -C /usr/local/bin hugo

# Working directory
WORKDIR /code

# Default command
CMD ["bash"]
